{
  "name": "color-tool",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@primer/octicons-react": "^17.2.0",
    "@primer/react": "^35.2.2",
    "@radix-ui/react-dialog": "^0.0.15",
    "@radix-ui/react-separator": "^0.0.12",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "@types/d3-scale": "^4.0.9",
    "@types/lodash-es": "^4.17.4",
    "@types/node": "^24.0.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/styled-components": "^5.1.9",
    "@xstate/immer": "^0.3.3",
    "@xstate/inspect": "^0.4.1",
    "@xstate/react": "^1.3.2",
    "bezier-easing": "^2.1.0",
    "color2k": "^1.2.4",
    "copy-to-clipboard": "^3.3.1",
    "d3-scale": "^4.0.2",
    "hsluv": "^0.1.0",
    "lodash-es": "^4.17.21",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-draggable": "^4.4.3",
    "react-hotkeys-hook": "^3.3.1",
    "react-router-dom": "^6.30.0",
    "react-use-measure": "^2.0.4",
    "styled-components": "^5.2.3",
    "uuid": "^14.0.0",
    "xstate": "^4.18.0"
  },
  "overrides": {
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.1"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build:preview": "tsc --noEmit && vite build",
    "build": "tsc --noEmit && vite build --base=/prism/",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint:fix": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prettier": "@github/prettier-config",
  "lint-staged": {
    "src/**/*.{ts,tsx}": "npm run lint"
  },
  "devDependencies": {
    "@github/prettier-config": "0.0.4",
    "@vitejs/plugin-react": "^4.0.0",
    "husky": "^8.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "13.0.2",
    "prettier": "2.7.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
